# Google Cloud Logging Configuration
GCP_PROJECT=your-gcp-project-id
LOG_NAME=loremipsumevents

# LLM Configuration (for gcloud_logs_llmsummary.py)
MODEL_NAME=gemini-2.0-flash-lite
